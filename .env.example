# GreenAPI Configuration
GREEN_API_URL=https://your-instance.api.greenapi.com
GREEN_API_ID=your_instance_id_here
GREEN_API_TOKEN=your_api_token_here

# WhatsApp Group Chat ID (required)
# All notifications will be sent to this group
# Format: 123456789012345@g.us
GREEN_API_GROUP_CHAT_ID=your_group_chat_id@g.us

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bin_collection?retryWrites=true&w=majority

# Cron Configuration
CRON_SECRET=your_secret_for_external_cron_auth_here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
ENABLE_SCHEDULER=true
NODE_ENV=development

# Admin Password (for protecting tenant and schedule management pages)
ADMIN_PASSWORD=admin123
